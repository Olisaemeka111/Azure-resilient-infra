############################
## DEV Environment — Example Values
## Copy to terraform.tfvars and update for your deployment.
## NEVER commit terraform.tfvars — it is in .gitignore.
############################

name_prefix     = "mr-secure-dev"
tenant_id       = "00000000-0000-0000-0000-000000000000"
subscription_id = "00000000-0000-0000-0000-000000000000"

primary_location   = "uksouth"
secondary_location = "ukwest"

primary_rg_name   = "rg-mr-secure-dev-uksouth"
secondary_rg_name = "rg-mr-secure-dev-ukwest"

############################
## Network Address Spaces
############################

primary_hub_address_space   = "10.0.0.0/16"
secondary_hub_address_space = "10.1.0.0/16"

primary_app_spoke_address_space    = "10.2.0.0/16"
primary_data_spoke_address_space   = "10.3.0.0/16"
secondary_app_spoke_address_space  = "10.4.0.0/16"
secondary_data_spoke_address_space = "10.5.0.0/16"

############################
## Hub Subnets
############################

primary_hub_firewall_subnet_prefix   = "10.0.0.0/26"
primary_hub_bastion_subnet_prefix    = "10.0.0.64/26"
# primary_hub_gateway_subnet_prefix  = "10.0.0.128/27"   # Uncomment when create_vpn_gateway = true

secondary_hub_firewall_subnet_prefix   = "10.1.0.0/26"
secondary_hub_bastion_subnet_prefix    = "10.1.0.64/26"
# secondary_hub_gateway_subnet_prefix  = "10.1.0.128/27" # Uncomment when create_vpn_gateway = true

############################
## App Spoke Subnets
############################

primary_app_aks_subnet_prefix   = "10.2.0.0/24"
secondary_app_aks_subnet_prefix = "10.4.0.0/24"

# primary_app_service_subnet_prefix   = "10.2.1.0/24"   # Uncomment when create_app_service = true
# secondary_app_service_subnet_prefix = "10.4.1.0/24"   # Uncomment when create_app_service = true

############################
## Data Spoke Subnets
############################

primary_data_sql_subnet_prefix   = "10.3.0.0/24"
secondary_data_sql_subnet_prefix = "10.5.0.0/24"

primary_private_endpoints_subnet_prefix   = "10.3.1.0/24"
secondary_private_endpoints_subnet_prefix = "10.5.1.0/24"

############################
## AKS
############################

aks_primary_node_count   = 3
aks_secondary_node_count = 1
aks_node_size            = "Standard_DS3_v2"

############################
## SQL
## sql_admin_password is NOT set here.
## It is retrieved from Azure Key Vault (ops-kv-mr-dev) by the CI/CD pipeline.
## For local runs: export TF_VAR_sql_admin_password="YourStr0ngP@ssword!" before terraform plan/apply
############################

sql_admin_username = "sqladmindev"
# sql_admin_password — injected at runtime from Azure Key Vault: secret name "sql-admin-password"
sql_sku_name       = "GP_Gen5_2"

############################
## Storage
############################

storage_account_name_prefix = "mrsecuredevstor"

############################
## Optional Services
############################

create_vpn_gateway = false
create_app_service = false

############################
## Container Registry
############################

registry_name = "mrsecuredevacr"   # Must be globally unique

############################
## Monitoring
############################

monitoring_retention_days = 30
alert_email               = "devops-dev@contoso.com"

############################
## Governance
############################

security_contact_email = "security-dev@contoso.com"
allowed_locations      = ["uksouth", "ukwest"]
# ops_principal_id     = "00000000-0000-0000-0000-000000000000"  # Uncomment to enable ops RBAC

############################
## Tags
############################

tags = {
  environment = "dev"
  workload    = "multi-region-secure-azure"
  managed_by  = "terraform"
}
