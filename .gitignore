# Terraform state - NEVER commit these
*.tfstate
*.tfstate.*
*.tfstate.backup

# Terraform working directory
.terraform/
.terraform.lock.hcl

# Plan files (may contain sensitive values)
*.tfplan
terraform.tfplan

# Variable files with real values - only commit *.tfvars.example
*.tfvars
!*.tfvars.example

# Crash logs
crash.log
crash.*.log

# Sensitive override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# CLI configuration (may contain credentials)
.terraformrc
terraform.rc

# OS files
.DS_Store
Thumbs.db

# IDE
.idea/
.vscode/
*.swp
*.swo
